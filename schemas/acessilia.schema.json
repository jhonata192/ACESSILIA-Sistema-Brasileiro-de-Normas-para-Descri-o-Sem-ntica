{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://acessilia.org/schemas/acessilia.schema.json",
  "title": "ACESSILIA Metadata Schema",
  "description": "Validates metadata for all ACESSILIA families (200-800). Supports both nested and flat structures. Standardize on flat structure.",
  "version": "1.1.0",
  "type": "object",
  "definitions": {
    "educationalContext": {
      "type": "object",
      "description": "Educational context metadata. Family 500.",
      "properties": {
        "theme": { "type": "string" },
        "targetAudience": { "type": "string" },
        "level": { "type": "string", "enum": ["Introductory", "Intermediate", "Advanced"] }
      },
      "additionalProperties": false
    },
    "citationMetadata": {
      "type": "object",
      "description": "Citation metadata. Family 400.",
      "properties": {
        "publisher": { "type": "string" },
        "version": { "type": "string" },
        "datePublished": { "type": "string", "format": "date" },
        "author": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the description (UUID or ACL-FAM-TIPO-NNN format)."
    },
    "description": {
      "type": "string",
      "description": "Text description of the content."
    },
    "language": {
      "type": "string",
      "description": "BCP 47 language tag for the content (e.g., pt-BR, en-US)."
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier or URL."
    },
    "standard": {
      "type": "string",
      "description": "Standard name and version (e.g., 'ACESSILIA 1.0')."
    },
    "date": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 date/time of creation or last update."
    },
    "reviewStatus": {
      "type": "string",
      "enum": ["draft", "reviewed", "approved", "rejected", "deprecated"],
      "description": "Review status of the description."
    },
    "reviewer": {
      "type": "string",
      "description": "Name or identifier of the reviewer."
    },
    "model": {
      "type": "string",
      "description": "Name of the AI model used (if applicable)."
    },
    "modelVersion": {
      "type": "string",
      "description": "Version of the AI model used (if applicable)."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score (0-1) of the description quality."
    },
    "uncertainty": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of uncertainty factors identified in the description."
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Known limitations of the description."
    },
    "metadata": {
      "type": "object",
      "description": "Optional nested metadata object (flat structure preferred).",
      "additionalProperties": true
    },
    "privacyNotice": {
      "type": "boolean",
      "description": "Indicates if privacy notice is required (PII detected). Family 200."
    },
    "contrastWarning": {
      "type": "boolean",
      "description": "Indicates if contrast warning is needed. Family 200."
    },
    "familyId": {
      "type": "integer",
      "enum": [200, 300, 400, 500, 600, 700, 800],
      "description": "Family identifier for the content type."
    },
    "conformsTo": {
      "type": "string",
      "description": "EPUB accessibility conformance claim."
    },
    "accessMode": {
      "type": "array",
      "items": { "type": "string" },
      "description": "EPUB access modes (e.g., textual, visual)."
    },
    "accessibilityFeature": {
      "type": "array",
      "items": { "type": "string" },
      "description": "EPUB accessibility features."
    },
    "accessibilityHazard": {
      "type": "array",
      "items": { "type": "string" },
      "description": "EPUB accessibility hazards."
    },
    "accessibilitySummary": {
      "type": "string",
      "description": "EPUB accessibility summary."
    },
    "accessModeSufficient": {
      "type": "array",
      "items": { "type": "string" },
      "description": "EPUB access modes sufficient (e.g., textual, visual)."
    },
    "accessibilityAPI": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Accessibility APIs supported (e.g., UIAutomation, MSAA)."
    },
    "accessibilityControl": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Input methods controlled (e.g., keyboard, voice, switch)."
    },
    "imageType": {
      "type": "string",
      "description": "Image MIME type (e.g., image/jpeg, image/png). Family 200."
    },
    "resolution": {
      "type": "string",
      "description": "Image resolution. Family 200."
    },
    "chartType": {
      "type": "string",
      "description": "Chart type (e.g., bar, line). Family 300."
    },
    "source": {
      "type": "string",
      "description": "Data source for charts. Family 300."
    },
    "xAxis": {
      "type": "object",
      "description": "X-axis metadata. Family 300."
    },
    "yAxis": {
      "type": "object",
      "description": "Y-axis metadata. Family 300."
    },
    "colors": {
      "type": "object",
      "description": "Color mapping for charts. Family 300."
    },
    "title": {
      "type": "string",
      "description": "Title of scientific content. Family 400."
    },
    "author": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Authors of scientific content. Family 400."
    },
    "doi": {
      "type": "string",
      "description": "DOI identifier. Family 400."
    },
    "bibliography": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Bibliography entries (DOI/URL). Family 400."
    },
    "dataAvailability": {
      "type": "string",
      "description": "URL for data availability. Family 400."
    },
    "citationMetadata": {
      "$ref": "#/definitions/citationMetadata"
    },
    "educationalContext": {
      "$ref": "#/definitions/educationalContext"
    },
    "learningObjectives": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Learning objectives with Bloom verbs. Family 500."
    },
    "sequence": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Sequence of topics. Family 500."
    },
    "examples": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Examples and contra-examples. Family 500."
    },
    "mediaType": {
      "type": "string",
      "description": "MIME type for multimedia. Family 600."
    },
    "duration": {
      "type": "string",
      "description": "Duration in ISO 8601. Family 600."
    },
    "narrativeDescription": {
      "type": "string",
      "description": "Narrative description of multimedia. Family 600."
    },
    "subtitles": {
      "type": "string",
      "description": "URL for subtitles file. Family 600."
    },
    "audioDescription": {
      "type": "boolean",
      "description": "Audio description available. Family 600."
    },
    "transcript": {
      "type": "string",
      "description": "Full transcript text. Family 600."
    },
    "conformanceLevel": {
      "type": "string",
      "enum": ["A", "AA", "AAA"],
      "description": "Conformance level declaration. Family 800."
    },
    "profiles": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Accessibility profiles defined. Family 800."
    },
    "mediaTypes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "MIME types for the profile. Family 800."
    },
    "requiredMetadata": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Required metadata fields for the profile. Family 800."
    }
  },
  "required": ["id", "description", "language", "license", "standard", "date", "reviewStatus"],
  "additionalProperties": true
}
